# Copy to .env and adjust. Used by scripts/start_merged.sh (optional `set -a; source .env`).

# --- Council (FastAPI / LangGraph) ---
# Ollama for council scan-system (see config/settings.yaml)
# OLLAMA_HOST=http://127.0.0.1:11434

# --- COA Flask (COA/COA_Project/web_api.py on 5050) ---
COA_FLASK_URL=http://127.0.0.1:5050
COA_PROJECT_DIR=COA/COA_Project

# COA LLM (see COA_Project .env and config)
# COA_LLM_MODEL=llama3.1:latest
# COA_LLM_BASE_URL=http://127.0.0.1:11434

# Optional: VirusTotal in COA
# VT_API_KEY=

# COA dev-only flags (see web_api.py)
# COA_ALLOW_DEV_TESTS=0
# COA_ALLOW_CLI_RUN=0
